<Window x:Class="DesktopMemo.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:DesktopMemo.App.Converters"
        xmlns:loc="clr-namespace:DesktopMemo.App.Localization"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        mc:Ignorable="d"
        Title="{loc:Localize MainWindow_Title_Memo}"
        Width="380"
        Height="300"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI, Microsoft YaHei"
        FontSize="14"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        KeyDown="MainWindow_KeyDown">

    <Border x:Name="MainContainer" Style="{StaticResource GlassmorphismBorder}" Margin="0">

        <Grid ClipToBounds="True">
            <Grid PreviewMouseLeftButtonDown="MainContentArea_PreviewMouseLeftButtonDown">
                <Grid.RowDefinitions>
                    <RowDefinition Height="44" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#10FFFFFF"
                        CornerRadius="16,16,0,0"
                        BorderBrush="#15FFFFFF"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8" Margin="0,0,10,0">
                                <Ellipse.Fill>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#FF00E676" Offset="0" />
                                        <GradientStop Color="#FF4CAF50" Offset="1" />
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>

                            <StackPanel Orientation="Horizontal" Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <Button Background="Transparent" BorderThickness="0" Padding="0" Command="{Binding ToggleTodoListCommand}" Cursor="Hand" ToolTip="{Binding LocalizationService[Tooltip_ToggleMode]}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <ContentPresenter />
                                        </ControlTemplate>
                                    </Button.Template>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Foreground="#F0FFFFFF" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding LocalizationService[MainWindow_Title_Memo]}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsInTodoListMode}" Value="True">
                                                            <Setter Property="Text" Value="{Binding LocalizationService[MainWindow_Title_Todo]}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock FontSize="12" Foreground="#B0FFFFFF" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding MemoCount, StringFormat=' ({0})'}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsInTodoListMode}" Value="True">
                                                            <Setter Property="Text" Value="{Binding TodoListViewModel.IncompleteTodoCount, StringFormat=' ({0})'}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding LocalizationService[MainWindow_Title_Edit]}" Foreground="#F0FFFFFF" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <Button Width="32" Height="32" Margin="0,0,8,0" Command="{Binding TogglePinCommand}" Style="{StaticResource GlassButton}" ToolTip="{Binding LocalizationService[Tooltip_Pin]}">
                                    <Path Data="M16,12V4H17V2H7V4H8V12L6,14V16H11.2V22H12.8V16H18V14L16,12Z" Width="16" Height="16" Stretch="Uniform">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Fill" Value="#E0FFFFFF"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsWindowPinned}" Value="True">
                                                        <Setter Property="Fill" Value="#FFFFA500"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                </Button>
                                <Button Width="32" Height="32" Margin="0,0,8,0">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource GlassButton}">
                                            <Setter Property="Command" Value="{Binding CreateMemoCommand}" />
                                            <Setter Property="ToolTip" Value="{Binding LocalizationService[Button_New]}" />
                                            <Style.Triggers>
                                                <!-- Todo模式 + 输入区域可见: 显示"取消"提示 -->
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsInTodoListMode}" Value="True" />
                                                        <Condition Binding="{Binding TodoListViewModel.IsInputVisible}" Value="True" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Command" Value="{Binding TodoListViewModel.ToggleInputCommand}" />
                                                    <Setter Property="ToolTip" Value="{Binding LocalizationService[Tooltip_CancelNewTodo]}" />
                                                </MultiDataTrigger>
                                                <!-- Todo模式 + 输入区域隐藏: 显示"新建待办事项"提示 -->
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsInTodoListMode}" Value="True" />
                                                        <Condition Binding="{Binding TodoListViewModel.IsInputVisible}" Value="False" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Command" Value="{Binding TodoListViewModel.ToggleInputCommand}" />
                                                    <Setter Property="ToolTip" Value="{Binding LocalizationService[Tooltip_NewTodo]}" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Path Width="16" Height="16" Stretch="Uniform" Fill="#E0FFFFFF">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <!-- 默认: 新建图标 (加号) -->
                                                <Setter Property="Data" Value="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" />
                                                <Style.Triggers>
                                                    <!-- Todo模式 + 输入区域可见: 显示向上箭头 (折叠) -->
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsInTodoListMode}" Value="True" />
                                                            <Condition Binding="{Binding TodoListViewModel.IsInputVisible}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Data" Value="M7.41,15.41L12,10.83L16.59,15.41L18,14L12,8L6,14L7.41,15.41Z" />
                                                    </MultiDataTrigger>
                                                    <!-- Todo模式 + 输入区域隐藏: 显示加号 (新建) -->
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsInTodoListMode}" Value="True" />
                                                            <Condition Binding="{Binding TodoListViewModel.IsInputVisible}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Data" Value="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                </Button>
                                <Button Width="32" Height="32" Margin="0,0,8,0" Command="{Binding ToggleSettingsCommand}" Style="{StaticResource GlassButton}" ToolTip="{Binding LocalizationService[Button_Settings]}">
                                    <Path Data="M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8M12,10A2,2 0 0,0 10,12A2,2 0 0,0 12,14A2,2 0 0,0 14,12A2,2 0 0,0 12,10M10,22C9.75,22 9.54,21.82 9.5,21.58L9.13,18.93C8.5,18.68 7.96,18.34 7.44,17.94L4.95,18.95C4.73,19.03 4.46,18.95 4.34,18.73L2.34,15.27C2.22,15.05 2.27,14.78 2.46,14.63L4.57,12.97C4.53,12.65 4.5,12.33 4.5,12C4.5,11.67 4.53,11.34 4.57,11.03L2.46,9.37C2.27,9.22 2.22,8.95 2.34,8.73L4.34,5.27C4.46,5.05 4.73,4.96 4.95,5.05L7.44,6.05C7.96,5.66 8.5,5.32 9.13,5.07L9.5,2.42C9.54,2.18 9.75,2 10,2H14C14.25,2 14.46,2.18 14.5,2.42L14.87,5.07C15.5,5.32 16.04,5.66 16.56,6.05L19.05,5.05C19.27,4.96 19.54,5.05 19.66,5.27L21.66,8.73C21.78,8.95 21.73,9.22 21.54,9.37L19.43,11.03C19.47,11.34 19.5,11.66 19.5,12C19.5,12.34 19.47,12.65 19.43,12.97L21.54,14.63C21.73,14.78 21.78,15.05 21.66,15.27L19.66,18.73C19.54,18.95 19.27,19.04 19.05,18.95L16.56,17.95C16.04,18.34 15.5,18.68 14.87,18.93L14.5,21.58C14.46,21.82 14.25,22 14,22H10" Fill="#E0FFFFFF" Width="16" Height="16" Stretch="Uniform" />
                                </Button>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Button Width="32" Height="32" Margin="0,0,8,0" Command="{Binding BackToListCommand}" Style="{StaticResource GlassButton}" ToolTip="{Binding LocalizationService[Tooltip_BackToList]}">
                                    <Path Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" Fill="#E0FFFFFF" Width="16" Height="16" Stretch="Uniform" />
                                </Button>
                                <Button Width="32" Height="32" Margin="0,0,8,0" Command="{Binding SaveAndBackCommand}" Style="{StaticResource GlassButton}" ToolTip="{Binding LocalizationService[Tooltip_SaveAndBack]}">
                                    <Path Data="M15,9H5V5H15M12,19A3,3 0 0,1 9,16A3,3 0 0,1 12,13A3,3 0 0,1 15,16A3,3 0 0,1 12,19M17,3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V7L17,3Z" Fill="#E0FFFFFF" Width="16" Height="16" Stretch="Uniform" />
                                </Button>
                                <Button Width="32" Height="32" Margin="0,0,8,0" Command="{Binding DeleteMemoCommand}" Style="{StaticResource GlassButton}" ToolTip="{Binding LocalizationService[Tooltip_Delete]}">
                                    <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Fill="#FFE57373" Width="16" Height="16" Stretch="Uniform" />
                                </Button>
                            </StackPanel>

                            <Button Width="32" Height="32" Click="CloseButton_Click" ToolTip="{Binding LocalizationService[Button_Close]}" Style="{StaticResource GlassButton}">
                                <Path Data="M13.46,12L19,17.54V19H17.54L12,13.46L6.46,19H5V17.54L10.54,12L5,6.46V5H6.46L12,10.54L17.54,5H19V6.46L13.46,12Z" Fill="#FFE57373" Width="16" Height="16" Stretch="Uniform" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="#08FFFFFF" CornerRadius="0,0,16,16" BorderBrush="#10FFFFFF" BorderThickness="0,1,0,0">
                    <Grid>
                        <!-- 备忘录列表 -->
                        <Grid Margin="0,-5,-10,-12">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsEditMode}" Value="False" />
                                                <Condition Binding="{Binding IsInTodoListMode}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <ListBox ItemsSource="{Binding Memos}"
                                     SelectedItem="{Binding SelectedMemo}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="8,5,8,8"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Visible"
                                     ScrollViewer.CanContentScroll="True"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling"
                                     VirtualizingPanel.ScrollUnit="Pixel">
                                <ListBox.Template>
                                    <ControlTemplate TargetType="ListBox">
                                        <ScrollViewer Style="{StaticResource GlassScrollViewer}"
                                                     Focusable="False"
                                                     Padding="{TemplateBinding Padding}">
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </ControlTemplate>
                                </ListBox.Template>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="VerticalContentAlignment" Value="Top"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter SnapsToDevicePixels="True"/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="12" Padding="14" BorderBrush="#05FFFFFF" BorderThickness="1" Height="80" Margin="0,5" VerticalAlignment="Center" Cursor="Hand">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#0DFFFFFF"/>
                                                    <Setter Property="BorderBrush" Value="#05FFFFFF"/>
                                                </Style>
                                            </Border.Style>
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.EnterEditModeCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}"/>
                                            </Border.InputBindings>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center" Width="150">
                                                    <TextBlock Text="{Binding DisplayTitle}" Foreground="#F0FFFFFF" FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding UpdatedAt, StringFormat='更新：{0:MM/dd HH:mm}'}" Foreground="#80FFFFFF" FontSize="11"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Preview}"
                                                           Foreground="#B0FFFFFF"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,0,12,0"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <!-- 待办事项列表 -->
                        <Grid Margin="4,0,0,0">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsEditMode}" Value="False" />
                                                <Condition Binding="{Binding IsInTodoListMode}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- 添加新待办事项的输入框 -->
                            <Border x:Name="TodoInputBorder" Grid.Row="0" Background="#15FFFFFF" CornerRadius="12" Padding="12" Margin="8,8,8,8" Visibility="{Binding TodoListViewModel.IsInputVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="NewTodoTextBox" Grid.Column="0"
                                             Text="{Binding TodoListViewModel.NewTodoContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="#F0FFFFFF"
                                             FontSize="13"
                                             CaretBrush="#FF64B5F6"
                                             VerticalAlignment="Center"
                                             Margin="0,0,8,0"
                                             Loaded="NewTodoTextBox_Loaded">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter" Command="{Binding TodoListViewModel.AddTodoCommand}" />
                                        </TextBox.InputBindings>
                                    </TextBox>
                                    <TextBlock Grid.Column="0" 
                                               Text="{Binding LocalizationService[Todo_Placeholder]}" 
                                               Foreground="#60FFFFFF" 
                                               FontSize="13"
                                               IsHitTestVisible="False"
                                               VerticalAlignment="Center"
                                               Margin="2,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TodoListViewModel.NewTodoContent}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Button Grid.Column="1" 
                                            Width="28" Height="28" 
                                            Command="{Binding TodoListViewModel.AddTodoCommand}" 
                                            Style="{StaticResource GlassButton}" 
                                            ToolTip="{Binding LocalizationService[Tooltip_AddTodo]}">
                                        <Path Data="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z" Fill="#E0FFFFFF" Width="14" Height="14" Stretch="Uniform" />
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- 待办事项列表区域 -->
                            <ScrollViewer Grid.Row="1" 
                                          Style="{StaticResource GlassScrollViewer}"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="8,0,8,8">
                                <StackPanel>
                                    <!-- 未完成的待办事项 -->
                                    <TextBlock Text="{Binding LocalizationService[Todo_Section_Incomplete]}" 
                                               Foreground="#B0FFFFFF" 
                                               FontSize="12" 
                                               FontWeight="SemiBold" 
                                               Margin="4,4,0,8"
                                               Visibility="{Binding TodoListViewModel.IncompleteTodoCount, Converter={StaticResource CountToVisibilityConverter}}" />
                                    <ItemsControl ItemsSource="{Binding TodoListViewModel.IncompleteTodos}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#0DFFFFFF"
                                                        CornerRadius="10"
                                                        Padding="10"
                                                        Margin="0,0,0,6"
                                                        BorderBrush="#10FFFFFF"
                                                        BorderThickness="1">
                                                    <Border.InputBindings>
                                                        <MouseBinding MouseAction="LeftDoubleClick"
                                                                      Command="{Binding DataContext.TodoListViewModel.BeginEditTodoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                      CommandParameter="{Binding}" />
                                                    </Border.InputBindings>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <CheckBox Grid.Column="0"
                                                                  IsChecked="{Binding IsCompleted, Mode=OneWay}"
                                                                  Command="{Binding DataContext.TodoListViewModel.ToggleTodoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  CommandParameter="{Binding}"
                                                                  VerticalAlignment="Center"
                                                                  Margin="0,0,10,0"
                                                                  Style="{StaticResource RoundCheckBox}" />

                                                        <!-- 只读模式：显示 TextBlock -->
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Content}"
                                                                   Foreground="#F0FFFFFF"
                                                                   FontSize="13"
                                                                   TextWrapping="Wrap"
                                                                   VerticalAlignment="Center">
                                                            <TextBlock.Visibility>
                                                                <MultiBinding Converter="{StaticResource EqualityToVisibilityConverter}">
                                                                    <Binding Path="Id" />
                                                                    <Binding Path="DataContext.TodoListViewModel.EditingTodoId" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                                </MultiBinding>
                                                            </TextBlock.Visibility>
                                                        </TextBlock>

                                                        <!-- 编辑模式：显示 TextBox -->
                                                        <TextBox Grid.Column="1"
                                                                 x:Name="EditTodoTextBox"
                                                                 Text="{Binding DataContext.TodoListViewModel.EditingContent, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 Foreground="#F0FFFFFF"
                                                                 FontSize="13"
                                                                 Background="#20FFFFFF"
                                                                 BorderBrush="#40FFFFFF"
                                                                 BorderThickness="1"
                                                                 Padding="4"
                                                                 TextWrapping="Wrap"
                                                                 AcceptsReturn="False"
                                                                 VerticalAlignment="Center"
                                                                 Loaded="EditTodoTextBox_Loaded"
                                                                 LostFocus="EditTodoTextBox_LostFocus">
                                                            <TextBox.Visibility>
                                                                <MultiBinding Converter="{StaticResource InverseEqualityToVisibilityConverter}">
                                                                    <Binding Path="Id" />
                                                                    <Binding Path="DataContext.TodoListViewModel.EditingTodoId" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                                </MultiBinding>
                                                            </TextBox.Visibility>
                                                            <TextBox.InputBindings>
                                                                <KeyBinding Key="Enter"
                                                                            Command="{Binding DataContext.TodoListViewModel.SaveEditTodoCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                                <KeyBinding Key="Escape"
                                                                            Command="{Binding DataContext.TodoListViewModel.CancelEditTodoCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                            </TextBox.InputBindings>
                                                        </TextBox>

                                                        <Button Grid.Column="2"
                                                                Width="24" Height="24"
                                                                Command="{Binding DataContext.TodoListViewModel.DeleteTodoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource GlassButton}"
                                                                ToolTip="{Binding DataContext.LocalizationService[Tooltip_DeleteTodo], RelativeSource={RelativeSource AncestorType=Window}}"
                                                                Margin="8,0,0,0">
                                                            <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                                                  Fill="#FFE57373"
                                                                  Width="12" Height="12"
                                                                  Stretch="Uniform" />
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- 已完成的待办事项 -->
                                    <StackPanel Visibility="{Binding TodoListViewModel.CompletedTodoCount, Converter={StaticResource CountToVisibilityConverter}}" Margin="0,12,0,0">
                                        <Grid Margin="4,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" 
                                                       Text="{Binding LocalizationService[Todo_Section_Completed]}" 
                                                       Foreground="#80FFFFFF" 
                                                       FontSize="12" 
                                                       FontWeight="SemiBold" />
                                            <Button Grid.Column="2"
                                                    Content="{Binding LocalizationService[Button_Clear]}"
                                                    Command="{Binding TodoListViewModel.ClearCompletedCommand}"
                                                    Style="{StaticResource GlassButton}"
                                                    FontSize="11"
                                                    Padding="6,2"
                                                    Height="22" />
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding TodoListViewModel.CompletedTodos}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#08FFFFFF"
                                                            CornerRadius="10"
                                                            Padding="10"
                                                            Margin="0,0,0,6"
                                                            BorderBrush="#08FFFFFF"
                                                            BorderThickness="1">
                                                        <Border.InputBindings>
                                                            <MouseBinding MouseAction="LeftDoubleClick"
                                                                          Command="{Binding DataContext.TodoListViewModel.BeginEditTodoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                          CommandParameter="{Binding}" />
                                                        </Border.InputBindings>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <CheckBox Grid.Column="0"
                                                                      IsChecked="{Binding IsCompleted, Mode=OneWay}"
                                                                      Command="{Binding DataContext.TodoListViewModel.ToggleTodoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                      CommandParameter="{Binding}"
                                                                      VerticalAlignment="Center"
                                                                      Margin="0,0,10,0"
                                                                      Style="{StaticResource RoundCheckBox}" />

                                                            <!-- 只读模式：显示 TextBlock -->
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding Content}"
                                                                       Foreground="#60FFFFFF"
                                                                       FontSize="13"
                                                                       TextWrapping="Wrap"
                                                                       TextDecorations="Strikethrough"
                                                                       VerticalAlignment="Center">
                                                                <TextBlock.Visibility>
                                                                    <MultiBinding Converter="{StaticResource EqualityToVisibilityConverter}">
                                                                        <Binding Path="Id" />
                                                                        <Binding Path="DataContext.TodoListViewModel.EditingTodoId" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                                    </MultiBinding>
                                                                </TextBlock.Visibility>
                                                            </TextBlock>

                                                            <!-- 编辑模式：显示 TextBox -->
                                                            <TextBox Grid.Column="1"
                                                                     x:Name="EditCompletedTodoTextBox"
                                                                     Text="{Binding DataContext.TodoListViewModel.EditingContent, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                     Foreground="#F0FFFFFF"
                                                                     FontSize="13"
                                                                     Background="#20FFFFFF"
                                                                     BorderBrush="#40FFFFFF"
                                                                     BorderThickness="1"
                                                                     Padding="4"
                                                                     TextWrapping="Wrap"
                                                                     AcceptsReturn="False"
                                                                     VerticalAlignment="Center"
                                                                     Loaded="EditTodoTextBox_Loaded"
                                                                     LostFocus="EditTodoTextBox_LostFocus">
                                                                <TextBox.Visibility>
                                                                    <MultiBinding Converter="{StaticResource InverseEqualityToVisibilityConverter}">
                                                                        <Binding Path="Id" />
                                                                        <Binding Path="DataContext.TodoListViewModel.EditingTodoId" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                                    </MultiBinding>
                                                                </TextBox.Visibility>
                                                                <TextBox.InputBindings>
                                                                    <KeyBinding Key="Enter"
                                                                                Command="{Binding DataContext.TodoListViewModel.SaveEditTodoCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                                    <KeyBinding Key="Escape"
                                                                                Command="{Binding DataContext.TodoListViewModel.CancelEditTodoCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                                                                </TextBox.InputBindings>
                                                            </TextBox>

                                                            <Button Grid.Column="2"
                                                                    Width="24" Height="24"
                                                                    Command="{Binding DataContext.TodoListViewModel.DeleteTodoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{StaticResource GlassButton}"
                                                                    ToolTip="删除"
                                                                    Margin="8,0,0,0">
                                                                <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                                                      Fill="#FFE57373"
                                                                      Width="12" Height="12"
                                                                      Stretch="Uniform" />
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <!-- 编辑备忘录 -->
                        <Grid Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBox x:Name="NoteTextBox" Text="{Binding EditorContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="Transparent" Foreground="#F0FFFFFF" BorderThickness="0" Padding="20" SpellCheck.IsEnabled="False" FontSize="14" CaretBrush="#FF64B5F6" SelectionBrush="#4064B5F6" TextChanged="NoteTextBox_TextChanged" PreviewKeyDown="NoteTextBox_PreviewKeyDown" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Border x:Name="QuickSettingsPanel" HorizontalAlignment="Right" VerticalAlignment="Stretch" Width="340" Background="{DynamicResource PrimaryBackgroundColor}" BorderThickness="0" CornerRadius="0,16,16,0" Visibility="{Binding IsSettingsPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}" MouseLeftButtonDown="QuickSettingsPanel_MouseLeftButtonDown">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.15"/>
                </Border.Effect>
                <Border.RenderTransform>
                    <TranslateTransform X="340" />
                </Border.RenderTransform>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Style="{StaticResource GlassScrollViewer}">
                    <StackPanel Margin="20,16,20,20">
                        <!-- 标题栏 -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding LocalizationService[Settings_Quick_Title]}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextColor}" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Width="32" Height="32" Command="{Binding ToggleSettingsCommand}" Background="{DynamicResource ButtonBackgroundColor}" BorderThickness="0" ToolTip="{Binding LocalizationService[Tooltip_Return]}" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#E8E8ED"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="16">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#D1D1D6"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#C7C7CC"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <Path Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" Fill="#1D1D1F" Width="16" Height="16" Stretch="Uniform" />
                            </Button>
                        </Grid>

                        <!-- 窗口置顶设置 -->
                        <Border Background="{DynamicResource CardBackgroundColor}" CornerRadius="12" Padding="16,14" Margin="0,0,0,12">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="0" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="{Binding LocalizationService[Settings_Topmost_Title]}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextColor}" Margin="0,0,0,12" />
                                <RadioButton Content="{Binding LocalizationService[Settings_Topmost_Normal]}" GroupName="TopmostMode" Style="{StaticResource ModernRadioButton}" IsChecked="{Binding SelectedTopmostMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Normal}" FontSize="13" Foreground="{DynamicResource PrimaryTextColor}" Margin="0,0,0,8" />
                                <RadioButton Content="{Binding LocalizationService[Settings_Topmost_Desktop]}" GroupName="TopmostMode" Style="{StaticResource ModernRadioButton}" IsChecked="{Binding SelectedTopmostMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Desktop}" FontSize="13" Foreground="{DynamicResource PrimaryTextColor}" Margin="0,0,0,8" />
                                <RadioButton Content="{Binding LocalizationService[Settings_Topmost_Always]}" GroupName="TopmostMode" Style="{StaticResource ModernRadioButton}" IsChecked="{Binding SelectedTopmostMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Always}" FontSize="13" Foreground="{DynamicResource PrimaryTextColor}" />
                            </StackPanel>
                        </Border>

                        <!-- 窗口位置设置 -->
                        <Border Background="{DynamicResource CardBackgroundColor}" CornerRadius="12" Padding="16,14" Margin="0,0,0,12">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="0" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="{Binding LocalizationService[Settings_Position_Title]}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextColor}" Margin="0,0,0,12" />
                                
                                <!-- 位置输入 -->
                                <StackPanel Margin="0,0,0,12">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding LocalizationService[Settings_Position_X]}" Foreground="{DynamicResource PrimaryTextColor}" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <TextBox Grid.Column="1" Text="{Binding CustomPositionX}" Background="{DynamicResource InputBackgroundColor}" Foreground="{DynamicResource PrimaryTextColor}" BorderBrush="{DynamicResource PrimaryBorderColor}" BorderThickness="1" Padding="8,6" FontSize="13" Height="32" VerticalContentAlignment="Center">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="TextBox">
                                                                <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                                                    <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="border" Property="BorderBrush" Value="#007AFF"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsFocused" Value="True">
                                                                        <Setter TargetName="border" Property="BorderBrush" Value="#007AFF"/>
                                                                        <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                        <TextBlock Grid.Column="3" Text="{Binding LocalizationService[Settings_Position_Y]}" Foreground="{DynamicResource PrimaryTextColor}" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <TextBox Grid.Column="4" Text="{Binding CustomPositionY}" Background="{DynamicResource InputBackgroundColor}" Foreground="{DynamicResource PrimaryTextColor}" BorderBrush="{DynamicResource PrimaryBorderColor}" BorderThickness="1" Padding="8,6" FontSize="13" Height="32" VerticalContentAlignment="Center">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="TextBox">
                                                                <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                                                                    <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="border" Property="BorderBrush" Value="#007AFF"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsFocused" Value="True">
                                                                        <Setter TargetName="border" Property="BorderBrush" Value="#007AFF"/>
                                                                        <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </Grid>
                                    <Button Command="{Binding ApplyCustomPositionCommand}" Height="32" FontSize="13" HorizontalAlignment="Stretch" Background="#007AFF" Foreground="White" BorderThickness="0" Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Content="{Binding LocalizationService[Button_Apply]}"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="#0051D5"/>
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="#004BB8"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>

                                <!-- 位置记忆按钮 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Command="{Binding RememberPositionCommand}" Grid.Column="0" Height="32" FontSize="13" Background="{DynamicResource ButtonBackgroundColor}" Foreground="{DynamicResource PrimaryTextColor}" BorderThickness="0" Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Content="{Binding LocalizationService[Settings_Position_Remember]}"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="#D1D1D6"/>
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="#C7C7CC"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Command="{Binding RestorePositionCommand}" Grid.Column="2" Height="32" FontSize="13" Background="{DynamicResource ButtonBackgroundColor}" Foreground="{DynamicResource PrimaryTextColor}" BorderThickness="0" Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Content="{Binding LocalizationService[Settings_Position_Restore]}"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="#D1D1D6"/>
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="#C7C7CC"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 外观设置 -->
                        <Border Background="{DynamicResource CardBackgroundColor}" CornerRadius="12" Padding="16,14" Margin="0,0,0,12">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="0" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="{Binding LocalizationService[Settings_Appearance_Title]}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextColor}" Margin="0,0,0,12" />
                                
                                <!-- 透明度设置 -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding LocalizationService[Settings_Opacity_Label]}" Foreground="{DynamicResource PrimaryTextColor}" FontSize="13" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding BackgroundOpacityPercent, StringFormat={}{0:F0}%}" Foreground="#007AFF" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                </Grid>
                                <Slider x:Name="BackgroundOpacitySlider" Minimum="0" Maximum="100" Value="{Binding BackgroundOpacityPercent, Mode=TwoWay}" ValueChanged="BackgroundOpacitySlider_ValueChanged" Height="24" Style="{StaticResource AppleSliderStyle}" />
                            </StackPanel>
                        </Border>

                        <!-- 语言设置 -->
                        <Border Background="{DynamicResource CardBackgroundColor}" CornerRadius="12" Padding="16,14" Margin="0,0,0,12">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="0" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="{Binding LocalizationService[Settings_Language_Title]}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextColor}" Margin="0,0,0,12" />
                                <TextBlock Text="{Binding LocalizationService[Settings_Language_Label]}" Foreground="{DynamicResource SecondaryTextColor}" FontSize="12" Margin="0,0,0,8" />
                                <ComboBox x:Name="LanguageComboBox"
                                          ItemsSource="{Binding AvailableLanguages}"
                                          SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                                          DisplayMemberPath="NativeName"
                                          Background="{DynamicResource InputBackgroundColor}"
                                          Foreground="{DynamicResource PrimaryTextColor}"
                                          BorderBrush="{DynamicResource PrimaryBorderColor}"
                                          BorderThickness="1"
                                          Padding="10,7"
                                          FontSize="13"
                                          Height="34">
                                    <ComboBox.ItemContainerStyle>
                                        <Style TargetType="ComboBoxItem">
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextColor}"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Padding" Value="12,8"/>
                                            <Setter Property="FontSize" Value="13"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ComboBoxItem">
                                                        <Border x:Name="Bd"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                Padding="{TemplateBinding Padding}"
                                                                CornerRadius="6">
                                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsHighlighted" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ItemHighlightColor}"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentColor}"/>
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ComboBox.ItemContainerStyle>
                                    <!-- 自定义下拉框模板 -->
                                    <ComboBox.Template>
                                        <ControlTemplate TargetType="ComboBox">
                                            <Grid>
                                                <ToggleButton x:Name="ToggleButton"
                                                              Grid.Column="2"
                                                              Focusable="false"
                                                              IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                              ClickMode="Press">
                                                    <ToggleButton.Template>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border x:Name="border"
                                                                    Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="8">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <ContentPresenter Grid.Column="0"
                                                                                      Margin="12,0,0,0"
                                                                                      HorizontalAlignment="Left"
                                                                                      VerticalAlignment="Center"
                                                                                      Content="{TemplateBinding Content}"/>
                                                                    <Path Grid.Column="1"
                                                                          Data="M7.41,8.58L12,13.17L16.59,8.58L18,10L12,16L6,10L7.41,8.58Z"
                                                                          Fill="{DynamicResource IconColor}"
                                                                          Width="12"
                                                                          Height="12"
                                                                          Stretch="Uniform"
                                                                          Margin="0,0,12,0"/>
                                                                </Grid>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="border" Property="BorderBrush" Value="#007AFF"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </ToggleButton.Template>
                                                    <ToggleButton.Style>
                                                        <Style TargetType="ToggleButton">
                                                            <Setter Property="Background" Value="{DynamicResource InputBackgroundColor}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBorderColor}"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                        </Style>
                                                    </ToggleButton.Style>
                                                </ToggleButton>
                                                <ContentPresenter x:Name="ContentSite"
                                                                  IsHitTestVisible="False"
                                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                                  Margin="12,0,30,0"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"/>
                                                <Popup x:Name="Popup"
                                                       Placement="Bottom"
                                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                                       AllowsTransparency="True"
                                                       Focusable="False"
                                                       PopupAnimation="Fade">
                                                    <Border x:Name="DropDownBorder"
                                                            Background="{DynamicResource CardBackgroundColor}"
                                                            BorderBrush="{DynamicResource PrimaryBorderColor}"
                                                            BorderThickness="1"
                                                            CornerRadius="10"
                                                            MinWidth="{TemplateBinding ActualWidth}"
                                                            MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                                            Padding="4">
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="0" Opacity="0.15"/>
                                                        </Border.Effect>
                                                        <ScrollViewer Margin="0" SnapsToDevicePixels="True">
                                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                                        </ScrollViewer>
                                                    </Border>
                                                </Popup>
                                            </Grid>
                                        </ControlTemplate>
                                    </ComboBox.Template>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- 其他设置 -->
                        <Border Background="{DynamicResource CardBackgroundColor}" CornerRadius="12" Padding="16,14" Margin="0,0,0,12">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="0" Opacity="0.08"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="{Binding LocalizationService[Settings_Other_Title]}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextColor}" Margin="0,0,0,12" />
                                <CheckBox Content="{Binding LocalizationService[Settings_ClickThrough]}" IsChecked="{Binding IsClickThroughEnabled, Mode=TwoWay}" Style="{StaticResource SettingsCheckBox}" Foreground="{DynamicResource PrimaryTextColor}" FontSize="13" />
                            </StackPanel>
                        </Border>

                        <Button Command="{Binding OpenSettingsWindowCommand}" Click="OpenSettingsWindowButton_Click" Height="40" HorizontalAlignment="Stretch" FontSize="14" FontWeight="SemiBold" Background="#007AFF" Foreground="White" BorderThickness="0" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Content="{Binding LocalizationService[Settings_OpenFullSettings]}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#0051D5"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#004BB8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</Window>
